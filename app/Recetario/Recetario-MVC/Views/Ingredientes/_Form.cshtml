@model IngredienteFormViewModel

<div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

<div class="row">
    <div class="col-4 mb-3">
        <label asp-for="Codigo" class="form-label"></label>
        <input asp-for="Codigo" class="form-control" readonly />
    </div>
    <div class="col-8 mb-3">
        <label asp-for="Descripcion" class="form-label"><span class="req text-danger">*</span> Descripción</label>
        <input asp-for="Descripcion" class="form-control" autofocus />
        <span asp-validation-for="Descripcion" class="text-danger"></span>
    </div>
</div>

<div class="mb-3">
    <label asp-for="IdUnidad" class="form-label"><span class="req text-danger">*</span> Unidad</label>
    <select asp-for="IdUnidad" asp-items="ViewBag.Unidades" class="form-select">
        <option value="">Elegí una unidad…</option>
    </select>
    <span asp-validation-for="IdUnidad" class="text-danger"></span>
</div>

@* El stock actual se maneja distinto en alta y edición: lo renderiza cada vista *@
