@model CrearUsuarioViewModel
@{
    ViewData["Title"] = "Nuevo usuario";
}
<div class="row justify-content-center">
    <div class="col-md-5">
        <form asp-action="Crear" method="post">
            <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

            <div class="row">
                <div class="col mb-3">
                    <label asp-for="Nombre" class="form-label"></label>
                    <input asp-for="Nombre" class="form-control" autofocus />
                    <span asp-validation-for="Nombre" class="text-danger"></span>
                </div>
                <div class="col mb-3">
                    <label asp-for="Apellido" class="form-label"></label>
                    <input asp-for="Apellido" class="form-control" />
                    <span asp-validation-for="Apellido" class="text-danger"></span>
                </div>
            </div>

            <div class="mb-3">
                <label asp-for="Email" class="form-label"></label>
                <input asp-for="Email" class="form-control" autocomplete="off" />
                <span asp-validation-for="Email" class="text-danger"></span>
            </div>

            <div class="mb-3">
                <label asp-for="Password" class="form-label"></label>
                <input asp-for="Password" class="form-control" autocomplete="new-password" />
                <span asp-validation-for="Password" class="text-danger"></span>
                <div class="form-text">El usuario debería cambiarla en su primer ingreso.</div>
            </div>

            <div class="mb-4">
                <label asp-for="Rol" class="form-label"></label>
                <select asp-for="Rol" class="form-select">
                    <option value="">Elegí un rol…</option>
                    <option value="Admin">Admin</option>
                    <option value="Cocina">Cocina</option>
                </select>
                <span asp-validation-for="Rol" class="text-danger"></span>
            </div>

            <button type="submit" class="btn btn-primary">Crear usuario</button>
            <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
        </form>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
