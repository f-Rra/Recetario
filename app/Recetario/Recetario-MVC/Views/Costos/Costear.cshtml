@model CostearPaginaViewModel
@{
    ViewData["Title"] = $"Costeo — {Model.Receta}";
}

<div class="mb-3">
    <a asp-controller="Recetas" asp-action="Index" class="text-decoration-none">
        <i class="bi bi-arrow-left"></i> Volver a recetas
    </a>
</div>

<div class="row g-3">
    <div class="col-lg-8">
        <div class="card mb-3">
            <div class="card-body">
                <div class="d-flex justify-content-between align-items-center mb-3">
                    <h2 class="h6 fw-semibold mb-0">
                        @Model.Receta <span class="text-muted fw-normal">(@Model.Codigo · base @Model.PorcionesBase porciones)</span>
                    </h2>
                </div>

                <form asp-action="Calcular" method="post" class="d-flex align-items-end gap-2 mb-1">
                    <input type="hidden" name="idReceta" value="@Model.IdReceta" />
                    <div>
                        <label class="form-label" for="porciones">Porciones a costear</label>
                        <input type="number" id="porciones" name="porciones" value="@Model.Porciones"
                               min="1" class="form-control" style="width: 160px;" />
                    </div>
                    <button type="submit" class="btn btn-primary">Calcular</button>
                </form>
                <div class="form-text">
                    Las cantidades se escalan a las porciones pedidas usando el último precio vigente de cada ingrediente.
                </div>
            </div>
        </div>

        @if (Model.Resultado is not null)
        {
            <div class="card">
                <div class="card-body">
                    @if (Model.Resultado.IngredientesSinPrecio.Count > 0)
                    {
                        <div class="alert alert-danger">
                            <b>No se puede costear:</b> los siguientes ingredientes no tienen ningún precio cargado:
                            <ul class="mb-0 mt-1">
                                @foreach (var faltante in Model.Resultado.IngredientesSinPrecio)
                                {
                                    <li>@faltante</li>
                                }
                            </ul>
                        </div>
                        <p class="text-muted mb-0">
                            Cargalos desde <a asp-controller="Ingredientes" asp-action="Index">Ingredientes</a> (botón $) y volvé a calcular.
                        </p>
                    }
                    else if (Model.Resultado.Detalles.Count == 0)
                    {
                        <p class="text-muted mb-0">La receta no tiene ingredientes: no hay nada que costear.</p>
                    }
                    else
                    {
                        <h3 class="h6 fw-semibold mb-3">Desglose para @Model.Resultado.Porciones porciones</h3>
                        <table class="table align-middle mb-3">
                            <thead>
                                <tr>
                                    <th>Ingrediente</th>
                                    <th class="num">Cant. bruta</th>
                                    <th class="num">Precio vigente</th>
                                    <th>Proveedor</th>
                                    <th class="num">Subtotal</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var d in Model.Resultado.Detalles)
                                {
                                    <tr>
                                        <td>@d.Ingrediente</td>
                                        <td class="num">@d.CantBruta.ToString("N2") @d.Unidad</td>
                                        <td class="num">$ @d.PrecioUnitario.ToString("N2")</td>
                                        <td>@d.Proveedor</td>
                                        <td class="num">$ @d.Subtotal.ToString("N2")</td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="fw-semibold">
                                    <td colspan="4" class="text-end">Costo total</td>
                                    <td class="num">$ @Model.Resultado.CostoTotal.ToString("N2")</td>
                                </tr>
                                <tr class="fw-semibold">
                                    <td colspan="4" class="text-end">Costo por porción</td>
                                    <td class="num">$ @Model.Resultado.CostoUnitario.ToString("N2")</td>
                                </tr>
                            </tfoot>
                        </table>

                        <form asp-action="Registrar" method="post">
                            <input type="hidden" name="idReceta" value="@Model.IdReceta" />
                            <input type="hidden" name="porciones" value="@Model.Resultado.Porciones" />
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-save"></i> Registrar costeo
                            </button>
                        </form>
                    }
                </div>
            </div>
        }
    </div>

    <div class="col-lg-4">
        <div class="card">
            <div class="card-body">
                <h3 class="h6 fw-semibold mb-3">Historial de costeos</h3>
                @if (Model.Historial.Count == 0)
                {
                    <p class="text-muted mb-0">Sin costeos registrados.</p>
                }
                else
                {
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Fecha</th>
                                <th class="num">Porc.</th>
                                <th class="num">Total</th>
                                <th class="num">Por porción</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var c in Model.Historial)
                            {
                                <tr title="Registrado por @c.Usuario">
                                    <td>@c.Fecha.ToString("dd/MM/yyyy")</td>
                                    <td class="num">@c.Porciones</td>
                                    <td class="num">$ @c.CostoTotal.ToString("N2")</td>
                                    <td class="num">$ @c.CostoUnitario.ToString("N2")</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>
</div>
