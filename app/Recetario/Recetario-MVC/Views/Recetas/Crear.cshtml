@model RecetaFormViewModel
@{
    ViewData["Title"] = "Nueva receta";
}

<div class="row justify-content-center">
    <div class="col-md-6 col-lg-5">
        <div class="card">
            <div class="card-body">
                <form asp-action="Crear" method="post">
                    <div asp-validation-summary="ModelOnly" class="alert alert-danger py-2"></div>

                    <div class="row">
                        <div class="col-4 mb-3">
                            <label asp-for="Codigo" class="form-label"></label>
                            <input asp-for="Codigo" class="form-control" readonly />
                        </div>
                        <div class="col-8 mb-3">
                            <label asp-for="Nombre" class="form-label"><span class="req text-danger">*</span> Nombre</label>
                            <input asp-for="Nombre" class="form-control" autofocus />
                            <span asp-validation-for="Nombre" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-7 mb-3">
                            <label asp-for="IdClasificacion" class="form-label"><span class="req text-danger">*</span> Clasificación</label>
                            <select asp-for="IdClasificacion" asp-items="ViewBag.Clasificaciones" class="form-select">
                                <option value="">Elegí una clasificación…</option>
                            </select>
                            <span asp-validation-for="IdClasificacion" class="text-danger"></span>
                        </div>
                        <div class="col-5 mb-3">
                            <label asp-for="PorcionesBase" class="form-label"><span class="req text-danger">*</span> Porciones base</label>
                            <input asp-for="PorcionesBase" class="form-control" />
                            <span asp-validation-for="PorcionesBase" class="text-danger"></span>
                        </div>
                    </div>

                    <div class="form-check mb-4">
                        <input asp-for="Activo" class="form-check-input" />
                        <label asp-for="Activo" class="form-check-label"></label>
                    </div>

                    <button type="submit" class="btn btn-primary">Crear y cargar contenido</button>
                    <a asp-action="Index" class="btn btn-outline-secondary">Cancelar</a>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
