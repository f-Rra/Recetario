@model RecetaDetalleViewModel
@using RecetarioMVC.Data
@{
    ViewData["Title"] = Model.Nombre;
}

<div class="mb-3 d-flex justify-content-between align-items-center">
    <a asp-action="Index" class="text-decoration-none">
        <i class="bi bi-arrow-left"></i> Volver a recetas
    </a>
    @if (User.IsInRole(DbSeeder.RolAdmin))
    {
        <div class="d-flex gap-2">
            <a asp-controller="Costos" asp-action="Costear" asp-route-id="@Model.IdReceta" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-currency-dollar"></i> Costear
            </a>
            <a asp-action="Editar" asp-route-id="@Model.IdReceta" class="btn btn-outline-primary btn-sm">
                <i class="bi bi-pencil"></i> Editar
            </a>
        </div>
    }
</div>

<div class="card mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h2 class="h5 mb-1">@Model.Nombre <span class="text-muted fw-normal">(@Model.Codigo)</span></h2>
            <span class="text-muted">@Model.Clasificacion · @Model.PorcionesBase porciones base</span>
        </div>
        @if (Model.Activo)
        {
            <span class="badge rounded-pill badge-estado-ok">Activa</span>
        }
        else
        {
            <span class="badge rounded-pill text-bg-secondary">Inactiva</span>
        }
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-body">
                <h3 class="h6 fw-semibold mb-3">Ingredientes</h3>
                @if (Model.Ingredientes.Count == 0)
                {
                    <p class="text-muted mb-0">Sin ingredientes cargados.</p>
                }
                else
                {
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Ingrediente</th>
                                <th class="num">Cant. neta</th>
                                <th class="num">Cant. bruta</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ing in Model.Ingredientes)
                            {
                                <tr>
                                    <td>@ing.Ingrediente</td>
                                    <td class="num">@ing.CantNeta.ToString("N2") @ing.Unidad</td>
                                    <td class="num">@ing.CantBruta.ToString("N2") @ing.Unidad</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-body">
                <h3 class="h6 fw-semibold mb-3">Procedimiento</h3>
                @if (Model.Pasos.Count == 0)
                {
                    <p class="text-muted mb-0">Sin pasos cargados.</p>
                }
                else
                {
                    <ol class="mb-0">
                        @foreach (var paso in Model.Pasos)
                        {
                            <li class="mb-2">@paso.Descripcion</li>
                        }
                    </ol>
                }
            </div>
        </div>
    </div>
</div>
