@model List<ComandaListaItem>
@{
    ViewData["Title"] = "Comandas";
    var fecha = (DateOnly)ViewData["Fecha"]!;
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <form method="get" class="d-flex gap-2 align-items-center">
        <label for="fecha" class="form-label mb-0">Día</label>
        <input type="date" id="fecha" name="fecha" value="@fecha.ToString("yyyy-MM-dd")"
               class="form-control" style="width: 180px;" onchange="this.form.submit()" />
    </form>
    <a asp-action="Registrar" class="btn btn-primary"><i class="bi bi-plus-lg"></i> Registrar comanda</a>
</div>

<div class="card">
    <div class="card-body">
        @if (Model.Count == 0)
        {
            <div class="text-center text-muted py-4">
                <i class="bi bi-receipt" style="font-size: 28px; color: var(--sx-celeste);"></i>
                <p class="mb-0 mt-2">Sin comandas para el @fecha.ToString("dd/MM/yyyy").</p>
            </div>
        }
        else
        {
            <table class="table table-hover align-middle mb-0">
                <thead>
                    <tr>
                        <th>#</th>
                        <th>Receta</th>
                        <th>Sector</th>
                        <th class="num">Porciones</th>
                        <th>Responsable</th>
                        <th>Registrada por</th>
                        <th class="num">Modif.</th>
                        <th class="text-end"></th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var item in Model)
                    {
                        <tr>
                            <td>@item.IdComanda</td>
                            <td>@item.Receta</td>
                            <td>@item.Clasificacion</td>
                            <td class="num">@item.Porciones</td>
                            <td>@item.Responsable</td>
                            <td>@item.Usuario</td>
                            <td class="num">@item.CantidadModificaciones</td>
                            <td class="text-end">
                                <a asp-action="Detalle" asp-route-id="@item.IdComanda"
                                   class="btn btn-sm btn-outline-primary" title="Ver detalle">
                                    <i class="bi bi-eye"></i>
                                </a>
                            </td>
                        </tr>
                    }
                </tbody>
            </table>
        }
    </div>
</div>
