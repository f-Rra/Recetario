@model ComandaDetalleViewModel
@using RecetarioMVC.Models
@{
    ViewData["Title"] = $"Comanda #{Model.IdComanda}";
}

<div class="mb-3">
    <a asp-action="Index" class="text-decoration-none">
        <i class="bi bi-arrow-left"></i> Volver a comandas
    </a>
</div>

<div class="card mb-3">
    <div class="card-body d-flex justify-content-between align-items-center">
        <div>
            <h2 class="h5 mb-1">
                @Model.Receta <span class="text-muted fw-normal">(@Model.Codigo)</span>
            </h2>
            <span class="text-muted">
                @Model.Fecha.ToString("dd/MM/yyyy") · @Model.Clasificacion ·
                @Model.Porciones porciones · Responsable: @Model.Responsable ·
                Registrada por @Model.Usuario
            </span>
        </div>
        <a asp-controller="Recetas" asp-action="Detalle" asp-route-id="@Model.IdReceta"
           class="btn btn-outline-primary btn-sm">
            <i class="bi bi-journal-text"></i> Ver receta
        </a>
    </div>
</div>

<div class="row g-3">
    <div class="col-lg-5">
        <div class="card h-100">
            <div class="card-body">
                <h3 class="h6 fw-semibold mb-3">Ingredientes para @Model.Porciones porciones</h3>
                @if (Model.Ingredientes.Count == 0)
                {
                    <p class="text-muted mb-0">La receta no tiene ingredientes cargados.</p>
                }
                else
                {
                    <table class="table align-middle mb-0">
                        <thead>
                            <tr>
                                <th>Ingrediente</th>
                                <th class="num">Cantidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var ing in Model.Ingredientes)
                            {
                                <tr>
                                    <td>@ing.Ingrediente</td>
                                    <td class="num">@ing.Cantidad.ToString("N2") @ing.Unidad</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }
            </div>
        </div>
    </div>

    <div class="col-lg-7">
        <div class="card h-100">
            <div class="card-body">
                <h3 class="h6 fw-semibold mb-3">Modificaciones</h3>

                @if (Model.Modificaciones.Count == 0)
                {
                    <p class="text-muted">Sin modificaciones registradas.</p>
                }
                else
                {
                    <table class="table align-middle mb-3">
                        <thead>
                            <tr>
                                <th>Tipo</th>
                                <th>Original</th>
                                <th>Reemplazo/Agregado</th>
                                <th class="num">Cantidad</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var m in Model.Modificaciones)
                            {
                                <tr>
                                    <td><span class="badge rounded-pill badge-estado-bajo">@m.Tipo</span></td>
                                    <td>@(m.IngredienteOriginal ?? "—")</td>
                                    <td>@(m.IngredienteReemplazo ?? "—")</td>
                                    <td class="num">@m.Cantidad.ToString("N2") @m.Unidad</td>
                                </tr>
                            }
                        </tbody>
                    </table>
                }

                <hr />
                <h4 class="h6 fw-semibold mb-2">Agregar modificación</h4>
                <form asp-action="AgregarModificacion" method="post" class="row g-2 align-items-end">
                    <input type="hidden" asp-for="NuevaModificacion.IdComanda" />
                    <div class="col-6 col-lg-3">
                        <label asp-for="NuevaModificacion.Tipo" class="form-label"></label>
                        <select asp-for="NuevaModificacion.Tipo" class="form-select form-select-sm">
                            <option value="">Tipo…</option>
                            <option value="@((int)TipoModificacion.Sustitucion)">Sustitución</option>
                            <option value="@((int)TipoModificacion.Adicion)">Adición</option>
                            <option value="@((int)TipoModificacion.Eliminacion)">Eliminación</option>
                        </select>
                    </div>
                    <div class="col-6 col-lg-3">
                        <label asp-for="NuevaModificacion.IdIngredienteOriginal" class="form-label"></label>
                        <select asp-for="NuevaModificacion.IdIngredienteOriginal" asp-items="ViewBag.Ingredientes"
                                class="form-select form-select-sm">
                            <option value="">—</option>
                        </select>
                    </div>
                    <div class="col-6 col-lg-3">
                        <label asp-for="NuevaModificacion.IdIngredienteReemplazo" class="form-label"></label>
                        <select asp-for="NuevaModificacion.IdIngredienteReemplazo" asp-items="ViewBag.Ingredientes"
                                class="form-select form-select-sm">
                            <option value="">—</option>
                        </select>
                    </div>
                    <div class="col-4 col-lg-2">
                        <label asp-for="NuevaModificacion.Cantidad" class="form-label"></label>
                        <input asp-for="NuevaModificacion.Cantidad" class="form-control form-control-sm" placeholder="0,00" />
                    </div>
                    <div class="col-2 col-lg-1">
                        <button type="submit" class="btn btn-primary btn-sm w-100" title="Agregar">
                            <i class="bi bi-plus-lg"></i>
                        </button>
                    </div>
                </form>
                <div class="form-text mt-1">
                    Sustitución: original + reemplazo · Adición: solo agregado · Eliminación: solo original.
                    El stock se ajusta y queda auditado en movimientos.
                </div>
            </div>
        </div>
    </div>
</div>
