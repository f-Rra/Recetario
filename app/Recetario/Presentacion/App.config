<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <startup>
    <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.8.1" />
  </startup>
  <connectionStrings>
    <!-- Cadena de conexión a RecetarioDB. La lee AccesoDatos. Ajustar el Server según el equipo. -->
    <add name="RecetarioDB"
         connectionString="Server=.\SQLEXPRESS;Database=RecetarioDB;Integrated Security=True;TrustServerCertificate=True;"
         providerName="System.Data.SqlClient" />
  </connectionStrings>
</configuration>
